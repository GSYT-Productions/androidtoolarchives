@charset "utf-8";

.post-views.entry-meta > span { margin-right: 0px !important; line-height: =
1; }

.post-views.entry-meta > span.post-views-icon.dashicons { display: inline-b=
lock; font-size: 16px; line-height: 1; text-decoration: inherit; vertical-a=
lign: middle; }

.post-views.load-dynamic .post-views-count { color: rgba(255, 255, 255, 0);=
 transition: color 0.3s ease-in-out; position: relative; }

.post-views.load-dynamic.loaded .post-views-count { color: inherit; }

.post-views.load-dynamic.loading .post-views-count, .post-views.load-dynami=
c.loading .post-views-count::after { box-sizing: border-box; }

.post-views.load-dynamic .post-views-count::after { opacity: 0; transition:=
 opacity 0.3s ease-in-out; position: relative; color: rgb(102, 16, 242); }

.post-views.load-dynamic.loading .post-views-count::after { content: ""; di=
splay: block; width: 16px; border-radius: 50%; border-width: 2px; border-st=
yle: solid; border-image: initial; border-color: currentcolor rgba(255, 255=
, 255, 0); animation: 1s linear 0s infinite normal none running pvc-loading=
; position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%)=
; opacity: 1; }

@keyframes pvc-loading {=20
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
